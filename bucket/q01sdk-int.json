  "architecture": {
    "64bit": {
      "url": "https://sdk.q01.io/q01sdk/int/1.0.75/q01sdk-windows-amd64.zip",
      "hash": "2024155be9f000c141a24059ac680e7a9df4b702c71f339db3efec5fa00bfa64"
    },
    "arm64": {
