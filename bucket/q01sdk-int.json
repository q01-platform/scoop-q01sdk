  },
  "bin": [
    [
      "q01sdk.exe",
      "q01sdk-int"
    ]
  ],
  "post_install": [
    "$configDir = \"$env:USERPROFILE\\.q01sdk\"",
    "New-Item -ItemType Directory -Path $configDir -Force | Out-Null",
    "$envFile = \"$configDir\\.env\"",
    "if (-not (Test-Path $envFile)) { Set-Content -Path $envFile -Value \"Host=https://app-int.q01.io`r`nEnv=int`r`nDEVTOOL=devspace\" }"
  ]
}
